# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MCP Server Configuration
MCP_SERVER_PATH=../servers/mcp-neo4j-shan/dist/main/index.js

# Neo4j Configuration (for direct access if needed)
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# Processing Configuration
CHUNK_SIZE=4000
MAX_RETRIES=3
CONCURRENCY=2

# Logging
LOG_LEVEL=info 